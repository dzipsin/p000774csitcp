# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# SQLi DETECTION RULES
# Version 3
# Project P000774CSITCP
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~


# ------------------------------------------------------------
# PRIORITY 1: CRITICAL
# Confirmed exploit behaviour
# Active data extraction or authentication bypass
# ------------------------------------------------------------

# Rule 1: UNION SELECT Statement in URI
alert http any any -> any any (msg:"P1 - SQLi UNION SELECT in URI"; flow:to_server,established; http.uri; pcre:"/UNION\s+(ALL\s+)?SELECT/iU"; classtype:web-application-attack; priority:1; sid:1001001; rev:1;)

# Rule 2: UNION SELECT Statement in POST Body
alert http any any -> any any (msg:"P1 - SQLi UNION SELECT in POST Body"; flow:to_server,established; content:"POST"; http_method; http.request_body; pcre:"/UNION\s+(ALL\s+)?SELECT/iU"; classtype:web-application-attack; priority:1; sid:1001002; rev:1;)

# Rule 3: Database Function Calls in URI
alert http any any -> any any (msg:"P1 - SQLi Database Function Call in URI"; flow:to_server,established; http.uri; pcre:"/(version\(\)|database\(\)|user\(\)|schema\(\))/iU"; classtype:web-application-attack; priority:1; sid:1001003; rev:1;)

# Rule 4: OS Command Execution Attempt
alert http any any -> any any (msg:"P1 - SQLi OS Command Execution Attempt"; flow:to_server,established; http.uri; pcre:"/(xp_cmdshell|LOAD_FILE|INTO\s+OUTFILE|INTO\s+DUMPFILE)/iU"; classtype:web-application-attack; priority:1; sid:1001004; rev:1;)

# ------------------------------------------------------------
# PRIORITY 2: High
# Clear injection structure 
# Displays intent despite exploitation not fully being confirmed 
# Cover all common attack types 
# ------------------------------------------------------------

# Rule 5: Boolean-Based Blind SQLi in URI
alert http any any -> any any (msg:"P2 - SQLi Boolean-Based Blind Injection in URI"; flow:to_server,established; http.uri; pcre:"/(AND|OR)\s+\d+=\d+/iU"; classtype:web-application-attack; priority:2; sid:1001005; rev:1;)

# Rule 6: Time-Based Blind SQLi in URI
alert http any any -> any any (msg:"P2 - SQLi Time-Based Injection in URI"; flow:to_server,established; http.uri; pcre:"/(SLEEP\s*\(|WAITFOR\s+DELAY|pg_sleep\s*\(|BENCHMARK\s*\()/iU"; classtype:web-application-attack; priority:2; sid:1001006; rev:1;)

# Rule 7: Time-Based Blind SQLi in POST Body
alert http any any -> any any (msg:"P2 - SQLi Time-Based Injection in POST Body"; flow:to_server,established; content:"POST"; http_method; http.request_body; pcre:"/(SLEEP\s*\(|WAITFOR\s+DELAY|pg_sleep\s*\(|BENCHMARK\s*\()/iU"; classtype:web-application-attack; priority:2; sid:1001007; rev:1;)

# Rule 8: SQL Comment Sequences in URI
alert http any any -> any any (msg:"P2 - SQL Comment Sequence in URI"; flow:to_server,established; http.uri; pcre:"/(--|#|%23|\/\*)/iU"; classtype:web-application-attack; priority:2; sid:1001008; rev:1;)

# Rule 9: Information Schema Enumeration
alert http any any -> any any (msg:"P2 - SQLi Information Schema Enumeration"; flow:to_server,established; http.uri; pcre:"/information_schema\.(tables|columns)/iU"; classtype:web-application-attack; priority:2; sid:1001009; rev:1;)

# ------------------------------------------------------------
# PRIORITY 3: LOW
# Wide net and broad rules
# Detects SQL keywords along with structure characters 
# ------------------------------------------------------------

# Rule 10: SQL Keywords with Quote Characters in URI
alert http any any -> any any (msg:"P3 - SQLi Suspicious SQL Keywords in URI"; flow:to_server,established; http.uri; pcre:"/('|%27).*(SELECT|INSERT|UPDATE|DELETE|DROP|ALTER|UNION)/iU"; classtype:web-application-attack; priority:3; sid:1001010; rev:1;)

# Rule 11: SQL Keywords in POST Body
alert http any any -> any any (msg:"P3 - SQLi Suspicious SQL Keywords in POST Body"; flow:to_server,established; content:"POST"; http_method; http.request_body; pcre:"/('|%27).*(SELECT|INSERT|UPDATE|DELETE|DROP)/iU"; classtype:web-application-attack; priority:3; sid:1001011; rev:1;)

# Rule 12: URL-Encoded SQLi Characters in URI
alert http any any -> any any (msg:"P3 - SQLi URL-Encoded Characters in URI"; flow:to_server,established; http.uri; pcre:"/(%27|%23|%3D|%2D%2D|%23)/iU"; classtype:web-application-attack; priority:3; sid:1001012; rev:1;)

# Rule 13: SQLi Payload in Cookie or Header
alert http any any -> any any (msg:"P3 - SQLi Suspicious Payload in Header"; flow:to_server,established; pcre:"/('|%27).*(SELECT|UNION|DROP|INSERT|UPDATE)/iH"; classtype:web-application-attack; priority:3; sid:1001013; rev:1;)
