# Suricata Alert Dashboard configuration
# Format: TOML
#
# Set [model] provider to one of the [model.*] section names below.
# Only the section matching your chosen provider is used; the others are ignored.


# Web server
[server]
host       = "0.0.0.0"
port       = 5000
secret_key = "suricata-dashboard"    # change in production

# Log monitor
[monitor]
eve_log       = "/var/log/suricata/eve.json"
poll_interval = 0.5   # seconds between readline polls when no new data

# ---------------------------------------------------------------------------
# Incident grouping and lifecycle
# ---------------------------------------------------------------------------

[incident]
# How to group alerts into incidents:
#   "per_actor"       — all alerts from one source IP, regardless of attack type
#   "per_attack_type" — split by both source IP AND attack type
grouping_mode = "per_actor"

# Incident closes after this many minutes of silence from the source IP
# (sliding window — resets on every new alert from that IP).
# For the demo, keep this low (2–3 minutes).
time_window_minutes = 2.0

# Wait this long after the most recent alert before regenerating the report.
# Prevents thrashing when alerts arrive in bursts.
debounce_seconds = 3.0

# Where incident report JSON files are written.
reports_dir = "reports"

# How often the background sweeper checks for expired incidents.
sweep_interval_seconds = 10.0

# ---------------------------------------------------------------------------
# Analysis settings (used by ReportGenerator)
# ---------------------------------------------------------------------------

[analysis]
# Include Docker lab infrastructure context in the classification prompt.
# When true, the LLM knows that 172.18.0.x traffic on port 3306 is expected
# internal database communication, improving false positive detection.
# Set to false for a more realistic evaluation.
include_lab_context = true

# How to generate the incident narrative:
#   "llm"      — LLM generates narrative, vectors, suggestions (richer output, slower)
#   "template" — deterministic template-based narrative (fast, consistent)
summary_mode = "llm"

# Retries per LLM call on parse/validation failures
max_retries = 1

# ---------------------------------------------------------------------------
# Model shared settings
# ---------------------------------------------------------------------------

[model]
# Which backend to use. Must match one of the [model.*] section names below.
provider    = "ollama"

max_tokens  = 1024
temperature = 0.0   # 0.0 for deterministic classification output

# Optional system prompt prepended to every request (leave empty to omit).
# Note: the AI module uses its own specialised system prompt for classification.
# This field is for custom overrides in non-analysis use cases.
system_prompt = ""

# ---------------------------------------------------------------------------
# Provider: Anthropic (remote API)
# ---------------------------------------------------------------------------

[model.anthropic]
api_key    = ""           # or set via API_KEY env var (takes precedence)
model_name = "claude-sonnet-4-20250514"

# ---------------------------------------------------------------------------
# Provider: Ollama (local)
#
# Requires Ollama running: https://ollama.com
# Pull a model first, e.g.: ollama pull llama3.2
# ---------------------------------------------------------------------------

[model.ollama]
model_name      = "llama3.2"
base_url        = "http://localhost:11434"
request_timeout = 120

# ---------------------------------------------------------------------------
# Provider: llama.cpp HTTP server (local)
# ---------------------------------------------------------------------------

[model.llamacpp]
model_name      = ""
base_url        = "http://localhost:8080"
request_timeout = 120