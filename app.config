# Suricata Alert Dashboard configuration
# Format: TOML
#
# Set [model] provider to one of the [model.*] section names below.
# Only the section matching your chosen provider is used; the others are ignored.


# Web server
[server]
host       = "0.0.0.0"
port       = 5000
secret_key = "suricata-dashboard"    # change in production

# Log monitor
[monitor]
eve_log       = "/var/log/suricata/eve.json"
poll_interval = 0.5   # seconds between readline polls when no new data

# ---------------------------------------------------------------------------
# Analysis settings
# ---------------------------------------------------------------------------

[analysis]
# Include Docker lab infrastructure context in the classification prompt.
# When true, the LLM knows that 172.18.0.x traffic on port 3306 is expected
# internal database communication, improving false positive detection.
# Set to false for a more realistic evaluation (the LLM receives no hints
# about the lab environment). Document this as a known limitation.
include_lab_context = true

# How to generate the executive summary in the report.
# "llm"      — LLM generates a narrative summary and recommendations (richer output)
# "template" — deterministic template-based summary (consistent, no extra LLM call)
summary_mode = "llm"

# ---------------------------------------------------------------------------
# Model shared settings
# ---------------------------------------------------------------------------

[model]
# Which backend to use. Must match one of the [model.*] section names below.
provider    = "ollama"

max_tokens  = 1024
temperature = 0.0   # 0.0 for deterministic classification output

# Optional system prompt prepended to every request (leave empty to omit).
# Note: the AI module uses its own specialised system prompt for classification.
# This field is for custom overrides in non-analysis use cases.
system_prompt = ""

# ---------------------------------------------------------------------------
# Provider: Anthropic (remote API)
# ---------------------------------------------------------------------------

[model.anthropic]
api_key    = ""           # or set via API_KEY env var (takes precedence)
model_name = "claude-sonnet-4-20250514"

# ---------------------------------------------------------------------------
# Provider: Ollama (local)
#
# Requires Ollama running: https://ollama.com
# Pull a model first, e.g.: ollama pull llama3.2
# ---------------------------------------------------------------------------

[model.ollama]
model_name      = "llama3.2"
base_url        = "http://localhost:11434"
request_timeout = 120

# ---------------------------------------------------------------------------
# Provider: llama.cpp HTTP server (local)
#
# Requires llama.cpp built with server support.
# Start with: ./llama-server -m your-model.gguf --port 8080
#
# Supported: any GGUF model loaded at server start time.
# model_name is informational only (the server uses whatever was loaded).
# ---------------------------------------------------------------------------

[model.llamacpp]
model_name      = ""
base_url        = "http://localhost:8080"
request_timeout = 120