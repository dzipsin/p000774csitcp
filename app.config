# Suricata Alert Dashboard configuration
# Format: TOML
#
# Set [model] provider to one of the [model.*] section names below.
# Only Ollama ships today (capstone constraint: no paid / remote providers).


# Web server
[server]
host       = "0.0.0.0"
port       = 5000
secret_key = "suricata-dashboard"    # change in production

# Log monitor
[monitor]
eve_log       = "/var/log/suricata/eve.json"
poll_interval = 0.5   # seconds between readline polls when no new data

# ---------------------------------------------------------------------------
# Incident grouping and lifecycle
# ---------------------------------------------------------------------------

[incident]
# How to group alerts into incidents:
#   "per_actor"       — all alerts from one source IP, regardless of attack type
#   "per_attack_type" — split by both source IP AND attack type
grouping_mode = "per_actor"

# Incident closes after this many minutes of silence from the source IP
# (sliding window — resets on every new alert from that IP).
# For the demo, keep this low (2–3 minutes).
time_window_minutes = 2.0

# Wait this long after the most recent alert before regenerating the report.
# Prevents thrashing when alerts arrive in bursts.
debounce_seconds = 3.0

# How often the background sweeper checks for expired incidents.
sweep_interval_seconds = 10.0

# ---------------------------------------------------------------------------
# Storage (SQLite — hybrid indexed-columns + full template JSON blob)
# ---------------------------------------------------------------------------
#
# Supports cross-run history queries, aggregates, and retention cleanup.
# WAL mode + thread-local connections. Schema bootstrap is idempotent so the
# DB file is created on first run.

[storage]
db_path                  = "data/reports.db"
retention_days           = 90                  # 0 = never expire
cleanup_interval_seconds = 3600                # how often the retention sweeper runs (0 = no automatic cleanup)

# ---------------------------------------------------------------------------
# Analysis settings (used by ReportGenerator)
# ---------------------------------------------------------------------------

[analysis]
# Include Docker lab infrastructure context in the classification prompt.
# When true, the LLM knows that 172.18.0.x traffic on port 3306 is expected
# internal database communication, improving false positive detection.
# Set to false for a more realistic evaluation.

include_lab_context = true
# include_lab_context = false


# How to generate the incident narrative:
#   "llm"      — LLM generates narrative, vectors, suggestions (richer output, slower)
#   "template" — deterministic template-based narrative (fast, consistent)
summary_mode = "llm"

# Retries per LLM call on parse/validation failures
max_retries = 1

# ---------------------------------------------------------------------------
# Agent settings (Phase 4 — agentic ReAct loop)
#
# When mode = "single_shot" the system uses the original per-alert
# classification (one LLM call per alert). This is the evaluation baseline.
#
# When mode = "react" the system uses ReActAgent — a tool-using loop that
# can call get_alert_history / lookup_environment_context /
# get_attack_pattern_stats before classifying. Best with qwen2.5:3b.
# ---------------------------------------------------------------------------

[agent]
mode                     = "react"          # "single_shot" | "react"
# mode                     = "single_shot"  # baseline-for-eval, not for demo
max_iterations           = 3
tool_timeout_seconds     = 5.0
total_budget_seconds     = 30.0
reasoning_trace_enabled  = true

# Option F hybrid: before the LLM runs, the agent deterministically calls
# get_alert_history + lookup_environment_context (+ get_attack_pattern_stats
# when attack type is recognised) and seeds the reasoning_trace with the
# results. The LLM can still emit additional tool calls afterwards.
# Set false for evaluation ablation (pure LLM-driven tool use).
auto_enrichment          = true
# auto_enrichment          = false   # eval-only override


[agent.tools]
get_alert_history             = true
lookup_environment_context    = true
get_attack_pattern_stats      = true

# Environment-context entries used by lookup_environment_context.
# Each entry: pattern + match_type (exact_ip | cidr | url_prefix | url_contains)
# + optional role / description / classification_hint.

[[agent.environment.entries]]
pattern              = "172.18.0.2"
match_type           = "exact_ip"
role                 = "internal_database"
description          = "EXPECTED INTERNAL — MariaDB inside Docker bridge. Traffic between DVWA and this IP on port 3306 is benign internal database communication. Classify alerts where this is BOTH source and destination as likely_false_positive."
classification_hint  = "likely_false_positive_if_internal_only"

[[agent.environment.entries]]
pattern              = "172.18.0.0/16"
match_type           = "cidr"
role                 = "docker_bridge"
description          = "EXPECTED INTERNAL — Docker bridge subnet hosting DVWA + MariaDB. Lab infrastructure, not an attacker."
classification_hint  = "context_only"

[[agent.environment.entries]]
pattern              = "192.168.56.0/24"
match_type           = "cidr"
role                 = "host_only_network"
description          = "UNTRUSTED EXTERNAL — VirtualBox host-only network where the attacker simulator runs. Treat all traffic from this range as adversarial unless explicitly proven benign. This is NOT trusted internal infrastructure."
classification_hint  = "untrusted_source_likely_attacker"

[[agent.environment.entries]]
pattern              = "/vulnerabilities/sqli"
match_type           = "url_prefix"
role                 = "vulnerable_endpoint"
description          = "EXPECTED ATTACK TARGET — DVWA SQLi training endpoint. Requests to this path indicate someone is exercising the vulnerability."
classification_hint  = "expected_attack_target"

[[agent.environment.entries]]
pattern              = "/vulnerabilities/xss"
match_type           = "url_prefix"
role                 = "vulnerable_endpoint"
description          = "EXPECTED ATTACK TARGET — DVWA XSS training endpoint. Requests to this path indicate someone is exercising the vulnerability."
classification_hint  = "expected_attack_target"

# ---------------------------------------------------------------------------
# Model shared settings
# ---------------------------------------------------------------------------

[model]
# Which backend to use. Must match one of the [model.*] section names below.
provider    = "ollama"

max_tokens  = 1024
temperature = 0.0   # 0.0 for deterministic classification output

# Optional system prompt prepended to every request (leave empty to omit).
# Note: the AI module uses its own specialised system prompt for classification.
# This field is for custom overrides in non-analysis use cases.
system_prompt = ""

# ---------------------------------------------------------------------------
# Provider: Ollama (local)
#
# Requires Ollama running: https://ollama.com
# Pull a model first, e.g.: ollama pull qwen2.5:3b
# ---------------------------------------------------------------------------

[model.ollama]
model_name      = "qwen2.5:3b"
# model_name      = "llama3.2"        # baseline-for-eval, not for demo

base_url        = "http://localhost:11434"
request_timeout = 120